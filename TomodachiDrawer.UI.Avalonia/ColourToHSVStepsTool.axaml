<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TomodachiDrawer.UI.Avalonia.ColourToHSVStepsTool"
        Icon="/Assets/Icon.png"
        Title="Colour to HSV Steps Tool"
        Width="250" Height="205"
		MinWidth="200" MinHeight="205">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key='Light'>
                    <SolidColorBrush x:Key='TextBoxDisabledBackground'>#DEDEDE</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key='Dark'>
                    <SolidColorBrush x:Key='TextBoxDisabledBackground'>#151515</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
	</Window.Resources>
    <Window.Styles>
        <Style Selector="Grid.field">
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="ColumnSpacing" Value="5" />
        </Style>
        <Style Selector="Grid.field TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Grid.field.field--read-only TextBox">
            <Setter Property="Background" Value="{DynamicResource TextBoxDisabledBackground}"></Setter>
        </Style>
    </Window.Styles>
    <StackPanel Margin="8">
        <Grid Classes="field"
              ColumnDefinitions="60,*"
              Margin="0,0,0,35">
            <TextBlock Text="Hex:" />
            <TextBox x:Name="ColourHex"
                     Grid.Column="1"
                     PlaceholderText="#RRGGBB"
                     TextChanged="ColourHex_TextChanged" />
        </Grid>

        <Grid Classes="field field--read-only" ColumnDefinitions="60,*">
            <TextBlock x:Name="SatStepsLabel" Text="X:" />
            <TextBox x:Name="SatStepsOutput"
                     Grid.Column="1"
                     IsReadOnly="True" />
        </Grid>

        <Grid Classes="field field--read-only" ColumnDefinitions="60,*">
            <TextBlock x:Name="ValStepsLabel" Text="Y:" />
            <TextBox x:Name="ValStepsOutput"
                     Grid.Column="1"
                     IsReadOnly="True" />
        </Grid>

        <Grid Classes="field field--read-only" ColumnDefinitions="60,*">
            <TextBlock Text="Hue:" />
            <TextBox x:Name="HueStepsOutput"
                     Grid.Column="1"
                     IsReadOnly="True" />
        </Grid>
    </StackPanel>
</Window>
